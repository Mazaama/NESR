<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Candidate Application Form</title>
<style>
  body {
    font-family: Arial, sans-serif;
    background: #fff;
    margin: 0;
    padding: 20px;
  }
  .form-page {
    max-width: 900px;
    margin: auto;
    border: 1px solid #000;
    padding: 20px 30px;
    page-break-after: always;
  }
  .form-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 15px;
  }
  .form-header img {
    height: 60px;
  }
  .form-header h2 {
    text-align: center;
    flex: 1;
    font-size: 20px;
    text-transform: uppercase;
    margin: 0;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 15px;
  }
  td, th {
    border: 1px solid #000;
    padding: 6px;
    font-size: 14px;
    vertical-align: top;
  }
  th, .section-title {
    background: #d9ead3; /* light green */
    font-weight: bold;
    text-align: left;
  }
  .grey-row {
    background: #f2f2f2;
  }
  textarea, input[type="text"], input[type="email"], input[type="number"], input[type="date"] {
    width: 98%;
    border: none;
    font-size: 14px;
    padding: 4px;
  }
  textarea {
    min-height: 40px;
    resize: vertical;
  }
  .inline-radio {
    display: flex;
    align-items: center;
    gap: 15px;
  }
  .footer {
    margin-top: 10px;
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    align-items: center;
  }
  .print-btn {
    background: #fff;
    border: 1px solid #000;
    padding: 6px 12px;
    color: red;
    font-weight: bold;
    cursor: pointer;
  }
  .checkbox-row {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
  }
  .checkbox-row label {
    display: flex;
    align-items: center;
    gap: 3px;
  }
</style>
</head>
<body>

<!-- PAGE 1 -->
<div class="form-page">
  <div class="form-header">
    <img src="https://media.licdn.com/dms/image/v2/C4D0BAQGMNmBfN9jH5w/company-logo_200_200/company-logo_200_200/0/1630519609346/nationalenergyservices_logo?e=1760572800&v=beta&t=DODOSKqRh3R3-_vVtQ4p6fYOMaO0uw8pePyhORy9Bow" alt="NESR Logo">
    <h2>Candidate Application Form</h2>
  </div>

  <table>
    <tr>
      <td>Date :</td>
      <td><input type="date"></td>
      <td>Location :</td>
      <td><input type="text"></td>
    </tr>
    <tr>
      <td>Job Request #</td>
      <td><input type="text"></td>
      <td>Service Line :</td>
      <td><input type="text"></td>
    </tr>
    <tr>
      <td colspan="4">Position Applied : <input type="text"></td>
    </tr>
  </table>

  <table>
    <tr><td colspan="4" class="section-title">Candidate Personal Information</td></tr>
    <tr>
      <td>First Name :</td>
      <td><input type="text"></td>
      <td>e-mail address :</td>
      <td><input type="email"></td>
    </tr>
    <tr>
      <td>Family Name :</td>
      <td><input type="text"></td>
      <td>Tel :</td>
      <td><input type="text"></td>
    </tr>
    <tr>
      <td>Address :</td>
      <td><input type="text"></td>
      <td>Mobile No :</td>
      <td><input type="text"></td>
    </tr>
    <tr>
      <td>Other Information :</td>
      <td colspan="3"><textarea></textarea></td>
    </tr>
  </table>

  <table>
    <tr><td colspan="4" class="section-title">Health and Safety</td></tr>
    <tr>
      <td colspan="4">
        Do you have any medical condition or disability? 
        <div class="inline-radio">
          <label><input type="radio" name="medical"> No</label>
          <label><input type="radio" name="medical"> Yes</label>
        </div>
        If Yes please provide details:
        <textarea></textarea>
      </td>
    </tr>
  </table>

  <table>
    <tr><td colspan="4" class="section-title">Education, Qualification & Experience</td></tr>
    <tr>
      <td colspan="4">
        Can you briefly describe your background education, experience, and skills?  
        <textarea></textarea>
      </td>
    </tr>
  </table>

  <table>
    <tr><td colspan="4" class="section-title">General Information</td></tr>
    <tr><td colspan="4">How did you hear about NESR? What do you know about the company?  
      <textarea></textarea></td></tr>
    <tr><td colspan="4">Reason for applying for this position:  
      <textarea></textarea></td></tr>
    <tr><td colspan="4">What is your actual / last Occupation? (Company, Location, Position, Responsibilities)  
      <textarea></textarea></td></tr>
    <tr><td colspan="4">What were your key achievements in your last role?  
      <textarea></textarea></td></tr>
    <tr><td colspan="4">Tell me about a big challenge or difficulty you faced and how you dealt with it?  
      <textarea></textarea></td></tr>
    <tr><td colspan="4">What are your reasons to move to a new job and new company?  
      <textarea></textarea></td></tr>
    <tr><td colspan="4">Why do you want to work for our company? Why should the company hire you?  
      <textarea></textarea></td></tr>
    <tr><td colspan="4">What can you add to our company?  
      <textarea></textarea></td></tr>
    <tr><td colspan="4">What can the company add to you?  
      <textarea></textarea></td></tr>
  </table>

  <div class="footer">
    <span>QAF8013 Rv.0</span>
    <span>Page 1 of 2</span>
  </div>
</div>

<!-- PAGE 2 -->
<div class="form-page">
  <div class="form-header">
    <img src="https://media.licdn.com/dms/image/v2/C4D0BAQGMNmBfN9jH5w/company-logo_200_200/company-logo_200_200/0/1630519609346/nationalenergyservices_logo?e=1760572800&v=beta&t=DODOSKqRh3R3-_vVtQ4p6fYOMaO0uw8pePyhORy9Bow" alt="NESR Logo">
    <h2>Candidate Application Form (continued)</h2>
  </div>

  <table>
    <tr><td>What qualities do you think will be required for this job?</td></tr>
    <tr><td><textarea></textarea></td></tr>
    <tr><td>What are your strengths?</td></tr>
    <tr><td><textarea></textarea></td></tr>
    <tr><td>What are your weaknesses?</td></tr>
    <tr><td><textarea></textarea></td></tr>
    <tr><td>What are your main motivations in your career?</td></tr>
    <tr><td><textarea></textarea></td></tr>
    <tr><td>What are your career objectives? Where do you want to be in 5 years from now?</td></tr>
    <tr><td><textarea></textarea></td></tr>
    <tr><td>Will you be interested by any other position/career within the company?</td></tr>
    <tr><td><textarea></textarea></td></tr>
    <tr>
      <td>
        What is your preferred working system and occupation?  
        <div class="checkbox-row">
          <label><input type="checkbox"> Commuter</label>
          <label><input type="checkbox"> Resident</label>
          <label><input type="checkbox"> Field</label>
          <label><input type="checkbox"> Office</label>
          <label><input type="checkbox"> Operations</label>
          <label><input type="checkbox"> Maintenance</label>
          <label><input type="checkbox"> Support</label>
          <label><input type="checkbox"> Other</label>
        </div>
      </td>
    </tr>
  </table>

  <table>
    <tr><td>Do you have experience with Operations in UAE and in the Region?</td></tr>
    <tr><td>Experience in UAE: <input type="text"></td></tr>
    <tr><td>Experience in the Region: <input type="text"></td></tr>
  </table>

  <table>
    <tr><td>Do you have any Client’s approval in UAE for field operations?</td></tr>
    <tr>
      <td>
        ADNOC Onshore approval: <input type="text">  
        ADNOC Offshore approval: <input type="text">  
        Other: <input type="text">
      </td>
    </tr>
  </table>

  <table>
    <tr>
      <td>What is your current Salary <input type="number"></td>
      <td>What are your salary expectations <input type="number"></td>
    </tr>
    <tr>
      <td colspan="2">What is your notice period and your availability? <textarea></textarea></td>
    </tr>
    <tr>
      <td colspan="2">What is your current status visa in country? <input type="text"></td>
    </tr>
  </table>

  <table>
    <tr><td>Can you provide some professional references? (Name, Company, Position, Contact Number, email)</td></tr>
    <tr><td><textarea></textarea></td></tr>
    <tr><td>Is there any information about the job or company that you would like to know?</td></tr>
    <tr><td><textarea></textarea></td></tr>
  </table>

  <table>
    <tr><td>Date: <input type="date"></td></tr>
    <tr><td>Full Name: <input type="text"></td></tr>
    <tr><td>Signature: <input type="text"></td></tr>
  </table>

  <div class="footer">
    <span>QAF8013 Rv.0</span>
    <button class="print-btn" onclick="window.print()">Print this Form</button>
    <span>Page 2 of 2</span>
  </div>
</div>

</body>
</html>
